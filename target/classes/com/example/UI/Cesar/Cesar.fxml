<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.UI.Cesar.CesarController">

    <Label text="Cifrado César"/>

    <TextField fx:id="inputText" promptText="Texto"/>

    <TextField fx:id="keyText" promptText="Clave (numero o palabra)"/>

    <Button text="Cifrar" onAction="#handleEncrypt"/>
    <Button text="Descifrar" onAction="#handleDecrypt"/>

    <TextArea fx:id="resultText"/>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.UI.RailFence.RailFenceController"
      alignment="CENTER"
      spacing="14"
      prefWidth="560"
      prefHeight="460">

    <padding>
        <Insets top="22" right="24" bottom="22" left="24"/>
    </padding>

    <Label text="Cifrado Rail Fence"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <Label text="Organiza el mensaje en zigzag segun la cantidad de rieles."
           style="-fx-text-fill: #546e7a; -fx-font-size: 13px;"/>

    <VBox spacing="8">
        <Label text="Texto"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <TextArea fx:id="inputTextArea"
                  prefHeight="130"
                  promptText="Escribe aqui el texto a cifrar o descifrar..."/>
    </VBox>

    <VBox spacing="8">
        <Label text="Numero de rieles"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <TextField fx:id="railsField"
                   promptText="Ejemplo: 3"
                   prefWidth="180"/>
    </VBox>

    <HBox alignment="CENTER" spacing="12">
        <Button text="Cifrar"
                onAction="#encrypt"
                prefWidth="110"
                style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Descifrar"
                onAction="#decrypt"
                prefWidth="110"
                style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Limpiar"
                onAction="#clearAll"
                prefWidth="110"
                style="-fx-background-color: #90a4ae; -fx-font-weight: bold;"/>
    </HBox>

    <VBox spacing="8">
        <Label text="Resultado"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <TextArea fx:id="outputTextArea"
                  prefHeight="130"
                  editable="false"
                  promptText="Aqui aparecera el resultado..."/>
    </VBox>
    <HBox alignment="CENTER" spacing="10">
        <Button text="Menú Principal" 
                onAction="#goBackToMainMenu"
                prefWidth="200"
                prefHeight="45"
                style="-fx-background-color: #77bafc; 
                       -fx-text-fill: white; 
                       -fx-font-size: 14px; 
                       -fx-font-weight: bold; 
                       -fx-background-radius: 5; 
                       -fx-cursor: hand;"/>
    </HBox>

    <Label fx:id="statusLabel"
           text="Listo para trabajar con Rail Fence."
           style="-fx-font-size: 13px; -fx-text-fill: #263238;"/>

</VBox>
